# source = ~/.config/hypr/myColors.conf
### MONITORS ###
# See https://wiki.hyprland.org/Configuring/Monitors/
monitor=eDP-1,preferred,auto,1.2
# monitor=,preferred,auto,auto
### MY PROGRAMS ###
# See https://wiki.hyprland.org/Configuring/Keywords/
# Set programs that you use
$menu = wofi --show drun
$ass = wofi --show drun
$dol = XDG_MENU_PREFIX=arch- kbuildsycoca6
$bg = swaybg -i /home/ahmed/Downloads/a7_wallpapers/113231.jpg -m fill
$mico = zeditor /home/ahmed/.config/hypr/hyprland.conf
$waybarconf = zeditor /home/ahmed/.config/waybar/config.jsonc
$lockconf = zeditor /home/ahmed/.config/hypr/hyprlock.conf
$micro = micro
$scrn = ~/home/ahmed/s.sh
$scrnW = hyprshot -m window
#$al =
### AUTOSTART ###
# Autostart necessary processes (like notifications daemons, status bars, etc.)
# Or execute your favorite apps at launch like this:
# exec-once = sh -c "find ~/home/ahmed/Downloads/a7_wallpapers/ -type f | shuf -n 1 | xargs swaybg -i"
exec-once = syncthing
exec-once = sunshine
exec-once = xfce4-power-manager &

#exec-once = $waybar
exec-once = $bg
# exec-once = $terminal
exec-once = nm-applet & swaync
exec-once = waybar
exec-once = $dol
# & hyprpaper #& firefox
### ENVIRONMENT VARIABLES ###
# See https://wiki.hyprland.org/Configuring/Environment-variables/
env = XCURSOR_SIZE,15
env = HYPRCURSOR_SIZE,15
### LOOK AND FEEL ###
# Refer to https://wiki.hyprland.org/Configuring/Variables/
# https://wiki.hyprland.org/Configuring/Variables/#general
general {
    gaps_in = 1
    gaps_out = 5

    border_size = 3

    # https://wiki.hyprland.org/Configuring/Variables/#variable-types for info about colors
    col.active_border = rgba(33ccffee) rgba(00ff99ee) 45deg
    col.inactive_border = rgba(595959aa)
    resize_on_border = true

    # Please see https://wiki.hyprland.org/Configuring/Tearing/ before you turn this on
    allow_tearing = false

    layout = dwindle
}

# https://wiki.hyprland.org/Configuring/Variables/#decoration
decoration {
    rounding = 20

    # Change transparency of focused and unfocused windows
    active_opacity = 1.0
    inactive_opacity = 1.0

    drop_shadow = false
    shadow_range = 2
    shadow_render_power = 3
    col.shadow = rgba(1a1a1aee)

    # https://wiki.hyprland.org/Configuring/Variables/#blur
    blur {
        enabled = false
        size = 0
        passes = 1

        vibrancy = 0.1696
    }
}

# https://wiki.hyprland.org/Configuring/Variables/#animations
animations {
    enabled = true

    # Default animations, see https://wiki.hyprland.org/Configuring/Animations/ for more

    bezier = myBezier, 0.05, 0.9, 0.1, 1.05

    animation = windows, 1, 7, myBezier
    animation = windowsOut, 1, 7, default, popin 80%
    animation = border, 1, 10, default
    animation = borderangle, 1, 8, default
    animation = fade, 1, 7, default
    animation = workspaces, 1, 6, default
}

# See https://wiki.hyprland.org/Configuring/Dwindle-Layout/ for more
dwindle {
    pseudotile = true # Master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = true # You probably want this
}

# See https://wiki.hyprland.org/Configuring/Master-Layout/ for more
master {
    new_status = master
}
# https://wiki.hyprland.org/Configuring/Variables/#misc
misc {
    force_default_wallpaper = -1 # Set to 0 or 1 to disable the anime mascot wallpapers
    disable_hyprland_logo = false # If true disables the random hyprland logo / anime girl background. :(
}
#############
### INPUT ###
#############
# https://wiki.hyprland.org/Configuring/Variables/#input
input {
    kb_layout = us
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

    sensitivity = 0 # -1.0 - 1.0, 0 means no modification.
    touchpad {
        natural_scroll = false
        middle_button_emulation = true
        disable_while_typing = false
    }
}

# https://wiki.hyprland.org/Configuring/Variables/#gestures
gestures {
    workspace_swipe = true
}

# Example per-device config
# See https://wiki.hyprland.org/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}
###################
### KEYBINDINGS ###
###################
# See https://wiki.hyprland.org/Configuring/Keywords/
$mainMod = SUPER # Sets "Windows" key as main modifier
# Example binds, see https://wiki.hyprland.org/Configuring/Binds/ for more
bind = $mainMod, Q, exec, konsole
bind = $mainMod, C, killactive,
bind = SUPER, F4, killactive,
bind = SUPER_SHIFT, O, exec, orange-canvas
bind = $mainMod, ESCAPE, exit,
bind = $mainMod, E, exec, dolphin
bind = $mainMod, Z, exec, zeditor
bind = $mainMod, O, exec, obsidian
bind = $mainMod, B, exec, firedragon
bind = $mainMod, M, exec, moonlight
bind = $mainMod, X, exec, $micro
bind = $mainMod, P, exec, PPSSPPSDL
bind = $mainMod, T, togglefloating,
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, rofi -combi-modi drun -theme solarized -font "hack 18" -show combi -icon-theme "Papirus" -show-icons
# bind = $mainMod, R, exec, rofi -combi-modi window,drun,ssh -theme solarized -font "hack 18" -show combi -icon-theme "Papirus" -show-icons
# bind = $mainMod, R, exec, rofi -show drun
bind = $mainMod, SPACE, exec, rofi -combi-modi drun -theme solarized -font "hack 18" -show combi -icon-theme "Papirus" -show-icons
bind = $mainMod, F, exec, rofi -show window -icon-theme "Papirus" -show-icons
bind = $mainMod, D, exec, blender
bind = $mainMod, A, exec, minder
bind = $mainMod, W, exec, steam
bind = $mainMod, K, exec, krita
bind = $mainMod, L, exec, lmms
bind = $mainMod, I, exec, github-desktop
bind = $mainMod, H, exec, htop# to switch between windows in a floating workspace
bind = $mainMod, Tab, cyclenext,           # change focus to another window
bind = $mainMod, Tab, bringactivetotop,    # bring it to the top
binde = SUPER_SHIFT, right, resizeactive, 10 0
binde = SUPER_SHIFT, left, resizeactive, -10 0
binde = SUPER_SHIFT, up, resizeactive, 0 -10
binde = SUPER_SHIFT, down, resizeactive, 0 10
bind = SUPER_SHIFT, F11, fullscreen
bind = SUPER, F11, exec, /home/ahmed/toggle_waybar.sh
bind = SUPER_SHIFT, Z, exec, zeditor /home/ahmed/.config/blender/4.2/scripts/addons/a7_video_tools/
bind = SUPER_SHIFT, X, exec, zeditor /home/ahmed/.config/blender/4.2/scripts/addons/Blender-Car-Streamliner/
bind = SUPER_SHIFT, C, exec, zeditor /home/ahmed/.config/blender/4.2/scripts/addons/Unturned-Buliding-Starter-main/
bind = , Print, exec, /home/ahmed/s.sh
bind = SUPER_SHIFT, Print, exec, hyprshot -m window -- ksnip
bind = SUPER, Print, exec, hyprshot -m window -m active --o /home/ahmed/Pictures/Screenshots/ -- ksnip
bind = SUPER_SHIFT, L, exec, hyprlock
bind = SUPER_SHIFT, E, exec, $dol
bind = $mainMod, X, togglesplit, # dwindle
binde = SUPER_SHIFT_ALT, down, movecursor, 650 600
binde = SUPER_SHIFT_ALT, up, movecursor, 650 200
binde = SUPER_SHIFT_ALT, right, movecursor, 850 400
binde = SUPER_SHIFT_ALT, left, movecursor, 450 400
bind = SUPER_ALT, left, movewindow, l
bind = SUPER_ALT, up, movewindow, u
bind = SUPER_ALT, down, movewindow, d
bind = SUPER_ALT, right, movewindow, r
bind = SUPER_SHIFT, Q, exec, $mico
bind = SUPER_SHIFT, E, exec, $lockconf
bind = SUPER_SHIFT, W, exec, $waybarconf
# bind = , Print, exec, hyprshot -m window
# Move focus with mainMod + arrow keys
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d
# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10
# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10
# Example special workspace (scratchpad)
# bind = $mainMod, S, togglespecialworkspace, magic
# bind = $mainMod SHIFT, S, movetoworkspace, special:magic
# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1
# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow
# Laptop multimedia keys for volume and LCD brightness
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl s 10%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl s 10%-
# Requires playerctl
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

