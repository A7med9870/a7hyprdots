<layout>
  <theme>
    <var key="color_bg" value="#1e1e2e" />
    <var key="color_surface" value="#313244" />
    <var key="color_accent" value="#89dceb" />
    <var key="color_text" value="#cdd6f4" />
    <var key="color_text_translucent" value="#bac2de" />
  </theme>

  <elements>
    <div interactable="0">
      <rectangle
        max_width="600"
        padding="16"
        flex_direction="column"
        gap="8"
        color="~color_surface"
        border_color="~color_accent"
        border="2"
        round="8">

        <div flex_direction="row" padding="8" justify_content="space_between">
          <div flex_direction="column" align_items="center" gap="8" max_width="160" min_width="160">
            <sprite src="grab-help/controller-grip-joy.svg" min_width="128" min_height="128" max_width="128" max_height="128" flex_grow="1" />
            <label wrap="1" size="25" padding_left="16" padding_right="16" translation="GRAB.ADJUST_DISTANCE" align="center" color="~color_text"/>
          </div>
          <div flex_direction="column" align_items="center" gap="8" max_width="160" min_width="160">
            <sprite src="grab-help/controller-grip-trigger-joy.svg" min_width="128" min_height="128" max_width="128" max_height="128" flex_grow="1" />
            <label wrap="1" size="25" padding_left="16" padding_right="16" translation="GRAB.ADJUST_SIZE" align="center" color="~color_text"/>
          </div>
          <div flex_direction="column" align_items="center" gap="8" max_width="160" min_width="160">
            <sprite src="grab-help/controller-grip-b.svg" min_width="128" min_height="128" max_width="128" max_height="128" flex_grow="1" />
            <label wrap="1" size="25" padding_left="16" padding_right="16" translation="GRAB.UNRESTRICTED_MOVEMENT" align="center" color="~color_text"/>
          </div>
        </div>

        <!-- A simple separator -->
        <rectangle width="100%" height="2" color="~color_accent" />

        <div align_items="center" padding="8">
          <label display="none" id="grabbing_watch" wrap="1" size="20" padding_right="16" translation="GRAB.GRABBING_WATCH" color="~color_text"/>
          <label display="none" id="grabbing_static" wrap="1" size="20" padding_left="16" padding_right="16" translation="GRAB.GRABBING_STATIC" color="~color_text"/>
          <label display="none" id="grabbing_anchored" wrap="1" size="20" padding_left="16" padding_right="16" translation="GRAB.GRABBING_ANCHORED" color="~color_text"/>
          <label display="none" id="grabbing_anchored_edit" wrap="1" size="20" padding_left="16" padding_right="16" translation="GRAB.GRABBING_ANCHORED_EDIT" color="~color_text"/>
          <label display="none" id="grabbing_floating" wrap="1" size="20" padding_left="16" padding_right="16" translation="GRAB.GRABBING_FLOATING" color="~color_text"/>
          <label display="none" id="grabbing_follow" wrap="1" size="20" padding_left="16" padding_right="16" translation="GRAB.GRABBING_FOLLOW" color="~color_text"/>
        </div>

      </rectangle>
    </div>
  </elements>
</layout>
